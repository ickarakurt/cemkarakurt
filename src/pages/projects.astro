---
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import ProjectCard from "@components/ProjectCard";
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects", ({ data }) => {
  return !data.draft;
});

// Sort projects by featured first, then by title
const sortedProjects = projects.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return a.data.title.localeCompare(b.data.title);
});

// Get projects with raw markdown content
const projectsWithContent = sortedProjects.map(project => {
  return {
    ...project,
    rawContent: project.body,
  };
});
---

<Layout title={`Projects | ${SITE.title}`}>
  <Header activeNav="projects" />
  <Main
    pageTitle="Projects"
    pageDesc="A showcase of my recent work and side projects."
  >
    <ul class="grid grid-cols-1 md:grid-cols-1 gap-6">
      {
        projectsWithContent.map(({ data, rawContent }) => (
          <li>
            <ProjectCard frontmatter={data} rawContent={rawContent || ""} />
          </li>
        ))
      }
    </ul>
  </Main>

  <Footer />
</Layout>
