---
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import ExploreTabs from "@components/ExploreTabs.tsx";
import LinkButton from "@components/LinkButton.astro";
import Socials from "@components/Socials.astro";
import Tag from "@components/Tag.astro";
import { SOCIALS, SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import getReadingTime from "@utils/getReadingTime";
import getSortedContent from "@utils/getSortedContent";
import getUniqueTags from "@utils/getUniqueTags";
import { getCollection } from "astro:content";
import { slugifyStr } from "@utils/slugify";

const posts = await getCollection("blog");
const projects = await getCollection("projects", ({ data }) => {
  return !data.draft;
});

const sortedPosts = getSortedContent(posts);

// Get featured tags for homepage sections
const featuredTags = (await getCollection("tags"))
  .filter(tag => tag.data.isTop)
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

// Group posts by featured tags
const tagSections = featuredTags.map(tag => {
  const tagPosts = sortedPosts.filter(post => 
    post.data.tags.some(t => slugifyStr(t) === tag.id)
  );
  return {
    ...tag,
    posts: tagPosts
  };
}).filter(section => section.posts.length > 0);

const digestrProject =
  projects.find(project => project.id === "digestr") ??
  projects.find(({ data }) => data.featured) ??
  projects[0];

const tags = getUniqueTags(posts);
const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout>
  <Header />

  <div class="site-container-wide">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 py-8 lg:py-12" transition:animate="fade">
      {/* Sidebar */}
      <aside
        class="lg:w-72 flex-shrink-0 space-y-8 lg:sticky lg:top-8 lg:self-start lg:max-h-[calc(100vh-4rem)] lg:overflow-y-auto"
      >
        {/* Profile */}
        <div class="space-y-5">
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <span class="mono-accent shrink-0 mt-1 text-xs opacity-50"
                >01</span
              >
              <div class="space-y-2">
                <h1
                  class="font-display text-3xl lg:text-4xl font-bold tracking-tight text-skin-base leading-tight"
                >
                  Cem Karakurt
                </h1>
                <p
                  class="text-skin-accent font-mono text-xs uppercase tracking-widest"
                >
                  Senior Full Stack Engineer
                </p>
              </div>
            </div>

            <div class="pl-7">
              <p
                class="text-skin-base/70 text-sm leading-relaxed border-l border-skin-border/40 pl-4"
              >
                6+ years shipping scalable systems end-to-end — from
                architecture and APIs to frontend UX and CI/CD.
              </p>
            </div>

            <div class="pl-7 flex items-center gap-3 text-xs text-skin-base/50 font-mono">
              <div class="flex items-center gap-1.5">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <span>Berlin, DE</span>
              </div>
            </div>
          </div>

          <div class="pl-7 flex items-center gap-3">
            {socialCount > 0 && <Socials centered />}
          </div>

          <div class="flex items-center gap-2 pl-7">
            <a
              href="/rss.xml"
              class="group inline-flex items-center gap-1.5 text-xs font-mono text-skin-base/50 hover:text-skin-accent transition-colors"
            >
              <svg
                class="w-3 h-3"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path d="M4 11a9 9 0 0 1 9 9"></path>
                <path d="M4 4a16 16 0 0 1 16 16"></path>
                <circle cx="5" cy="19" r="1"></circle>
              </svg>
              <span>Subscribe</span>
            </a>
          </div>
        </div>

        {/* Topics */}
        <div class="space-y-3">
          <div class="flex items-center gap-2">
            <span class="mono-accent text-xs opacity-50">02</span>
            <h2
              class="font-display text-xs font-medium uppercase tracking-wider text-skin-base/60"
            >
              Topics
            </h2>
          </div>
          <ul class="flex flex-wrap gap-1.5 pl-6">
            {
              tags.slice(0, 15).map((tag, index) => (
                <li
                  class="stagger-in"
                  style={`animation-delay: ${index * 0.05}s`}
                >
                  <Tag tag={tag.tag} tagName={tag.tagName} size="sm" />
                </li>
              ))
            }
          </ul>
        </div>
      </aside>

      {/* Main Content */}
      <main id="main-content" class="flex-1 min-w-0 space-y-8">
        {/* Latest Posts */}
        <section class="space-y-3">
          <div class="flex items-center gap-3 border-b border-skin-border/40 pb-2.5">
            <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-skin-accent/10 text-skin-accent">
              <svg
                class="w-3.5 h-3.5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
              </svg>
            </span>
            <h2 class="font-display text-lg font-semibold text-skin-base tracking-tight">
              Latest
            </h2>
          </div>
          <ul class="space-y-1">
            {
              sortedPosts.slice(0, 3).map((post, index) => (
                <li
                  class="stagger-in"
                  style={`animation-delay: ${index * 0.04}s`}
                >
                  <a
                    href={`/blog/${post.id}/`}
                    class="group flex items-center gap-3 py-2.5 px-3 -mx-3 rounded-lg hover:bg-skin-card-muted/50 transition-all duration-200"
                  >
                    <span class="font-mono text-[10px] text-skin-base/20 shrink-0 tabular-nums w-5 text-right">
                      {String(index + 1).padStart(2, "0")}
                    </span>
                    <span class="text-sm font-medium text-skin-base group-hover:text-skin-accent transition-colors truncate">
                      {post.data.title}
                    </span>
                    <span class="flex items-center gap-2 ml-auto shrink-0 text-[11px] font-mono text-skin-base/30 tabular-nums">
                      <span class="hidden sm:inline">{getReadingTime(post.body || "")}</span>
                      <span class="hidden sm:inline w-px h-3 bg-skin-border/30"></span>
                      <span>
                        {post.data.pubDatetime.toLocaleDateString("en-US", {
                          month: "short",
                          year: "2-digit",
                        })}
                      </span>
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="space-y-4" id="explore-section">
          <div class="flex items-center gap-3 border-b border-skin-border/40 pb-2.5">
            <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-skin-accent/10 text-skin-accent">
              <svg
                class="w-3.5 h-3.5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="3" width="7" height="7" />
                <rect x="14" y="3" width="7" height="7" />
                <rect x="14" y="14" width="7" height="7" />
                <rect x="3" y="14" width="7" height="7" />
              </svg>
            </span>
            <h2 class="font-display text-lg font-semibold text-skin-base tracking-tight">
              Explore
            </h2>
          </div>

          <ExploreTabs sections={tagSections} client:load />
        </section>

        {/* Latest Project */}
        {
          digestrProject && (
            <section class="space-y-3">
              <div class="flex items-center gap-3 border-b border-skin-border/40 pb-2.5">
                <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-skin-accent/10 text-skin-accent">
                  <svg
                    class="w-3.5 h-3.5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" />
                    <polyline points="7.5 4.21 12 6.81 16.5 4.21" />
                    <polyline points="7.5 19.79 7.5 14.6 3 12" />
                    <polyline points="21 12 16.5 14.6 16.5 19.79" />
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                    <line x1="12" y1="22.08" x2="12" y2="12" />
                  </svg>
                </span>
                <h2 class="font-display text-lg font-semibold text-skin-base tracking-tight">
                  Latest Project
                </h2>
              </div>

              <article class="rounded-2xl border border-skin-accent/30 bg-skin-card p-5 sm:p-6">
                <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                  <div class="space-y-2">
                    <p class="font-mono text-xs uppercase tracking-wider text-skin-accent">
                      Spotlight
                    </p>
                    <h3 class="font-display text-2xl font-bold tracking-tight text-skin-base">
                      {digestrProject.data.title}
                    </h3>
                    {digestrProject.data.subtitle && (
                      <p class="text-sm text-skin-base/70 leading-relaxed max-w-2xl">
                        {digestrProject.data.subtitle}
                      </p>
                    )}
                  </div>

                  <div class="flex flex-wrap gap-2">
                    <a
                      href="/projects/"
                      class="inline-flex items-center gap-1.5 rounded-lg border border-skin-border px-3 py-2 text-xs font-mono uppercase tracking-wider text-skin-base/70 hover:text-skin-accent hover:border-skin-accent/40 transition-colors"
                    >
                      Project details
                    </a>
                    {digestrProject.data.address && (
                      <a
                        href={digestrProject.data.address}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1.5 rounded-lg border border-skin-accent/40 bg-skin-accent/10 px-3 py-2 text-xs font-mono uppercase tracking-wider text-skin-accent hover:bg-skin-accent/20 transition-colors"
                      >
                        Visit {digestrProject.data.title}
                      </a>
                    )}
                  </div>
                </div>
              </article>
            </section>
          )
        }
      </main>
    </div>
  </div>

  <Footer />

  <style>
    /* Custom scrollbar for sidebar */
    aside::-webkit-scrollbar {
      width: 4px;
    }
    aside::-webkit-scrollbar-track {
      background: transparent;
    }
    aside::-webkit-scrollbar-thumb {
      background: rgba(var(--color-accent), 0.2);
      border-radius: 2px;
    }
    aside::-webkit-scrollbar-thumb:hover {
      background: rgba(var(--color-accent), 0.4);
    }
  </style>
</Layout>
