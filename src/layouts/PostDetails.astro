---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Tag from "@components/Tag.astro";
import Datetime from "@components/Datetime";
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { slugifyStr } from "@utils/slugify";
import ShareLinks from "@components/ShareLinks.astro";
import Comments from "@components/Comments";
import getReadingTime from "@utils/getReadingTime";
import TableOfContents from "@components/TableOfContents.astro";
import ScrollProgress from "@components/ScrollProgress.astro";

export interface Props {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
}

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags,
} = post.data;

const { Content, headings } = await render(post);
const readingTime = getReadingTime(post.body || "");

const ogImageUrl = typeof ogImage === "string" ? ogImage : ogImage?.src;
const ogUrl = new URL(
  ogImageUrl ?? `/blog/${slugifyStr(title)}.png`,
  Astro.url.origin
).href;

const layoutProps = {
  title,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage: ogUrl,
  ogType: "article",
  scrollSmooth: true,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title }, id }) => ({
  id,
  title,
}));

const currentPostIndex = allPosts.findIndex(a => a.id === post.id);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex !== allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;
---

<Layout {...layoutProps}>
  <Header />
  <ScrollProgress />
  <div id="reading-tooltip" class="reading-tooltip"></div>

  <main id="main-content" class="pb-12">
    <div class="site-container">
      <div class="pt-8">
        <button
          class="focus-outline inline-flex items-center gap-1 text-skin-base/60 transition-colors duration-200 hover:text-skin-accent"
          onclick="(() => (history.length === 1) ? window.location = '/' : history.back())()"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5">
            <path
              d="M13.293 6.293 7.586 12l5.707 5.707 1.414-1.414L10.414 12l4.293-4.293z"
            ></path>
          </svg>
          <span class="text-sm font-medium">Go back</span>
        </button>
      </div>

      {/* Title and Meta Section */}
      <header class="mb-10 mt-6">
        <h1
          transition:name={slugifyStr(title)}
          class="font-display text-3xl font-bold leading-tight tracking-tight text-skin-base sm:text-4xl"
        >
          {title}
        </h1>
        <div class="mt-3 flex items-center gap-4 text-sm text-skin-base/50">
          <Datetime
            pubDatetime={pubDatetime}
            modDatetime={modDatetime}
            size="lg"
          />
          <span class="flex items-center gap-1.5 font-mono text-xs">
            <svg
              class="h-3.5 w-3.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            {readingTime}
          </span>
        </div>
      </header>

      {/* Layout Grid - Unified Narrative Column + Sidebar */}
      <div
        class="relative mt-12 grid grid-cols-1 items-start gap-12 lg:grid-cols-[minmax(0,48rem),250px] lg:justify-center"
      >
        {/* Main Content Column (Article + Pagination + Comments) */}
        <div class="site-prose lg:mx-0">
          <article
            id="article"
            class="prose prose-headings:scroll-mt-24 prose-headings:font-semibold"
          >
            <Content />
          </article>

          {/* Tags Section */}
          <div class="mt-8">
            <ul class="flex flex-wrap gap-2">
              {tags.map(tag => <Tag tag={slugifyStr(tag)} />)}
            </ul>
          </div>

          {/* Bottom Navigation & Share */}
          <div class="mt-12 space-y-8">
            <div
              class="flex flex-col-reverse items-center justify-between gap-6 sm:flex-row-reverse sm:items-end sm:gap-4"
            >
              <button
                id="back-to-top"
                class="inline-flex items-center gap-1 rounded-md px-3 py-1.5 text-sm font-medium text-skin-base/60 transition-colors duration-200 hover:bg-skin-card-muted/40 hover:text-skin-accent"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 rotate-90"
                >
                  <path
                    d="M13.293 6.293 7.586 12l5.707 5.707 1.414-1.414L10.414 12l4.293-4.293z"
                  ></path>
                </svg>
                <span>Back to Top</span>
              </button>
              <ShareLinks />
            </div>
            <hr class="border-skin-border/60" />
          </div>

          {/* Previous/Next Posts - Editorial Layout */}
          <div class="mt-20 border-t border-skin-border/40 pt-12">
            <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 sm:gap-16">
              {
                prevPost ? (
                  <a
                    href={`/blog/${prevPost.id}/`}
                    class="group flex flex-col gap-3 transition-opacity hover:opacity-80"
                  >
                    <div class="flex items-center gap-2 font-mono text-[10px] font-bold uppercase tracking-widest text-skin-base/30 transition-colors group-hover:text-skin-accent/60">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-3.5 w-3.5 transition-transform duration-300 group-hover:-translate-x-1"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                      >
                        <path d="M19 12H5M12 19l-7-7 7-7" />
                      </svg>
                      Previous Entry
                    </div>
                    <h4 class="font-display text-lg font-bold leading-tight text-skin-base transition-colors group-hover:text-skin-accent">
                      {prevPost.title}
                    </h4>
                  </a>
                ) : (
                  <div />
                )
              }

              {
                nextPost && (
                  <a
                    href={`/blog/${nextPost.id}/`}
                    class="group flex flex-col items-end gap-3 text-right transition-opacity hover:opacity-80"
                  >
                    <div class="flex items-center gap-2 font-mono text-[10px] font-bold uppercase tracking-widest text-skin-base/30 transition-colors group-hover:text-skin-accent/60">
                      Next Entry
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                      >
                        <path d="M5 12h14M12 5l7 7-7 7" />
                      </svg>
                    </div>
                    <h4 class="font-display text-lg font-bold leading-tight text-skin-base transition-colors group-hover:text-skin-accent">
                      {nextPost.title}
                    </h4>
                  </a>
                )
              }
            </div>
          </div>

          {/* Comments Section */}
          <div class="mt-12">
            <Comments client:only="react" />
          </div>
        </div>

        {
          /* Sidebar TOC Column (Stays sticky alongside entire Narrative column) */
        }
        <TableOfContents headings={headings} />
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script is:inline>
  /** Scrolls the document to the top when
   * the "Back to Top" button is clicked. */
  function setupBackToTop() {
    const backToTopBtn = document.querySelector("#back-to-top");
    if (backToTopBtn) {
      backToTopBtn.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    }
  }

  /** Attaches copy buttons and UI controls to code blocks. */
  function attachCodeBlockEnhancements() {
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      if (codeBlock.closest(".code-block-wrapper")) continue;

      // Extract language if available
      const codeElement = codeBlock.querySelector("code");
      let language = "";
      if (codeElement) {
        const langClass = Array.from(codeElement.classList).find(c =>
          c.startsWith("language-")
        );
        if (langClass) {
          language = langClass.replace("language-", "").toLowerCase();
        }
      }

      // Create main wrapper
      const wrapper = document.createElement("div");
      wrapper.className =
        "code-block-wrapper relative my-8 overflow-hidden rounded-xl border border-skin-border/80 bg-skin-card shadow-md transition-all duration-300 hover:shadow-lg dark:shadow-2xl dark:shadow-black/20 font-mono";

      // Create header
      const header = document.createElement("div");
      header.className =
        "flex items-center justify-between px-3 py-1.5 bg-skin-card-muted/30 border-b border-skin-border/40 select-none backdrop-blur-sm";

      // Mac buttons
      const buttons = document.createElement("div");
      buttons.className = "flex gap-1";
      ["bg-[#ff5f57]", "bg-[#febc2e]", "bg-[#28c840]"].forEach(colorClass => {
        const dot = document.createElement("div");
        dot.className = `w-2 h-2 rounded-full ${colorClass} opacity-80`;
        buttons.appendChild(dot);
      });

      // Info section (Language)
      const info = document.createElement("div");
      info.className = "flex items-center gap-3";

      if (language) {
        const langLabel = document.createElement("span");
        langLabel.className =
          "text-[10px] uppercase tracking-widest text-skin-base/40 font-bold";
        langLabel.innerText = language;
        info.appendChild(langLabel);
      }

      const copyButton = document.createElement("button");
      copyButton.className =
        "copy-code flex items-center gap-1 rounded-md px-1.5 py-1 text-[11px] font-medium text-skin-base/60 hover:text-skin-accent hover:bg-skin-accent/5 transition-all duration-200 outline-none focus-visible:ring-1 focus-visible:ring-skin-accent/30";
      copyButton.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
      `;

      info.appendChild(copyButton);
      header.appendChild(buttons);
      header.appendChild(info);

      // Move code block into wrapper
      codeBlock.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(header);
      wrapper.appendChild(codeBlock);

      // Reset pre styles
      codeBlock.style.margin = "0";
      codeBlock.style.borderRadius = "0";
      codeBlock.style.border = "none";
      codeBlock.style.boxShadow = "none";

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;
      const span = button.querySelector("span");
      const svg = button.querySelector("svg");

      await navigator.clipboard.writeText(text ?? "");

      if (span) span.innerText = "Copied";
      if (svg) svg.innerHTML = `<polyline points="20 6 9 17 4 12"></polyline>`;
      button.classList.add("text-skin-accent");

      setTimeout(() => {
        if (svg)
          svg.innerHTML = `<rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>`;
        button.classList.remove("text-skin-accent");
      }, 1500);
    }
  }

  /** Deep link headings */
  function setupAnchoredHeadings() {
    const headings = document.querySelectorAll(".prose h2, .prose h3");
    headings.forEach(heading => {
      heading.addEventListener("click", () => {
        const id = heading.id;
        if (!id) return;
        const url = new URL(window.location.href);
        url.hash = id;
        navigator.clipboard.writeText(url.toString());
        window.history.pushState({}, "", url);
      });
    });
  }

  if (typeof window.contentIndex === "undefined") {
    window.contentIndex = null;
  }

  async function setupAdvancedReadingFeatures() {
    const tooltip = document.getElementById("reading-tooltip");

    // --- Side-Notes & Footnotes ---
    const footnotes = document.querySelector("section[data-footnotes]");
    if (footnotes) {
      const refs = document.querySelectorAll("[data-footnote-ref]");
      const items = footnotes.querySelectorAll("li");

      refs.forEach((ref, index) => {
        const item = items[index];
        if (!item) return;

        // Shared popover behavior for both mobile and desktop
        // (This keeps footnotes "of the article" and avoids TOC collision)
        ref.addEventListener("click", e => {
          e.preventDefault();
          e.stopPropagation();
          showTooltip(e, item.innerHTML, "footnote");
        });

        // Optional: Hover support for footnotes too?
        // link.addEventListener("mouseenter", (e) => showTooltip(e, item.innerHTML, "footnote"));
      });
    }

    // --- Insight Link Previews ---
    const internalLinks = document.querySelectorAll(
      '.prose a[href*="/blog/"], .prose a[href*="/notes/"], a[href*="/tags/"]'
    );

    internalLinks.forEach(link => {
      link.addEventListener("mouseenter", async e => {
        const currentLink = e.currentTarget;
        try {
          if (!window.contentIndex) {
            const res = await fetch("/content-index.json");
            window.contentIndex = await res.json();
          }

          // Safety: Don't show if mouse left during the fetch
          if (!currentLink.matches(":hover")) return;

          const href = currentLink.getAttribute("href");
          const slug = href.split("/").filter(Boolean).pop();
          const entry = window.contentIndex.find(
            p => p.id === slug || p.slug === slug
          );

          if (entry) {
            const content = `
              <div class="space-y-2">
                <p class="font-mono text-[10px] uppercase tracking-widest text-skin-base/40 text-left">${entry.collection}</p>
                <h4 class="font-display font-semibold text-skin-base leading-tight text-left">${entry.title}</h4>
                <p class="text-xs text-skin-base/60 line-clamp-2 text-left">${entry.description}</p>
                <div class="flex items-center gap-3 pt-1 text-[10px] font-mono text-skin-accent/60">
                  <span>${entry.pubDate}</span>
                  <span class="w-1 h-1 rounded-full bg-skin-base/20"></span>
                  <span>${entry.readingTime}</span>
                </div>
              </div>
            `;
            showTooltip(e, content, "preview");
          }
        } catch (err) {
          console.error("Preview failed:", err);
        }
      });

      link.addEventListener("mouseleave", hideTooltip);
    });

    // --- Safety & Cleanup Listeners ---
    // Hide on any scroll (fixes the "sticky" bug)
    window.addEventListener("scroll", hideTooltip, { passive: true });

    // Hide on Escape key
    window.addEventListener("keydown", e => {
      if (e.key === "Escape") hideTooltip();
    });

    // Safety: Hide if mouse leaves the main document area
    document.addEventListener("mouseleave", hideTooltip);

    function showTooltip(e, html, type) {
      if (!tooltip) return;
      tooltip.innerHTML = html;

      // Position logic: Set values BEFORE making visible to avoid "top-left" jump
      const rect = e.currentTarget.getBoundingClientRect();
      const x = Math.min(window.innerWidth - 300, Math.max(20, rect.left));
      tooltip.style.left = `${x}px`;

      // Measure height after setting innerHTML but before adding "visible" animation
      const y = rect.top + window.scrollY - tooltip.offsetHeight - 15;
      tooltip.style.top = `${y}px`;

      tooltip.classList.add("visible");

      if (type === "footnote") {
        const closeHandler = () => {
          hideTooltip();
          document.removeEventListener("click", closeHandler);
        };
        setTimeout(() => document.addEventListener("click", closeHandler), 10);
      }
    }

    function hideTooltip() {
      if (tooltip) tooltip.classList.remove("visible");
    }
  }

  // Initial runs
  setupBackToTop();
  attachCodeBlockEnhancements();
  setupAnchoredHeadings();
  setupAdvancedReadingFeatures();

  // Pre-fetch content index for faster previews
  if (!window.contentIndex) {
    fetch("/content-index.json")
      .then(res => res.json())
      .then(data => (window.contentIndex = data))
      .catch(err => console.error("Failed to pre-fetch content index:", err));
  }

  // Re-run on view transitions
  document.addEventListener("astro:after-swap", () => {
    setupBackToTop();
    attachCodeBlockEnhancements();
    setupAnchoredHeadings();
    setupAdvancedReadingFeatures();
  });
</script>
